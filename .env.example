# Stork configuration
# Copy this file to .env and adjust as needed.
# All variables are optional — defaults work out of the box.

# Directory where the SQLite database and attachments are stored
# STORK_DATA_DIR=./data

# Port the HTTP server listens on
# STORK_PORT=3100

# Set to 1 to run in read-only demo mode with sample data
# STORK_DEMO_MODE=1
