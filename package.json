{
	"name": "stork",
	"version": "0.1.0",
	"description": "Self-hosted email client with IMAP sync, local storage, and full-text search",
	"type": "module",
	"scripts": {
		"dev": "tsx src/index.ts",
		"build": "esbuild src/index.ts --bundle --outdir=dist --platform=node --format=esm --packages=external",
		"start": "node dist/index.js",
		"test": "vitest run && cd frontend && npm test",
		"test:backend": "vitest run",
		"test:coverage": "STORK_FAST_KDF=1 vitest run --coverage && cd frontend && npx vitest run --coverage",
		"test:frontend": "cd frontend && npm test",
		"test:e2e": "vitest run tests/e2e-container.test.ts",
		"test:e2e-ui": "npx playwright test",
		"screenshots:generate": "npx playwright test --config playwright.screenshots.config.ts",
		"lint": "biome check .",
		"format": "biome format --write .",
		"db:migrate": "tsx src/storage/migrate.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.11",
		"@noble/hashes": "^2.0.1",
		"better-sqlite3-multiple-ciphers": "^12.8.0",
		"bip39": "^3.1.0",
		"hono": "^4.7.0",
		"imapflow": "^1.0.171",
		"mailparser": "^3.9.4",
		"nodemailer": "^8.0.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@playwright/test": "^1.58.2",
		"@types/mailparser": "^3.4.6",
		"@types/node": "^25.5.0",
		"@types/nodemailer": "^7.0.11",
		"@vitest/coverage-v8": "^4.1.0",
		"esbuild": "^0.25.0",
		"happy-dom": "^20.8.4",
		"tsx": "^4.19.0",
		"vitest": "^4.1.0"
	},
	"license": "AGPL-3.0-only"
}
