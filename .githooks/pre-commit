#!/usr/bin/env bash
# Pre-commit hook: run lint + tests before allowing commits.
# This prevents broken commits from reaching the public repo.
#
# Install: git config core.hooksPath .githooks
set -euo pipefail

# Use fast KDF params for tests — production Argon2id params are too slow for
# a pre-commit hook. Matches CI behavior.
export STORK_FAST_KDF=1

# Heartbeat: emit a progress marker every 30s so long-running stages
# don't look like they've hung (especially in non-TTY contexts).
_heartbeat_pid=
_start_heartbeat() {
  (while true; do sleep 30; echo "[pre-commit heartbeat: $(date +%H:%M:%S)]"; done) &
  _heartbeat_pid=$!
}
_stop_heartbeat() {
  if [[ -n "${_heartbeat_pid:-}" ]]; then
    kill "$_heartbeat_pid" 2>/dev/null || true
    wait "$_heartbeat_pid" 2>/dev/null || true
    _heartbeat_pid=
  fi
}
trap _stop_heartbeat EXIT
_start_heartbeat

echo "=== Pre-commit: running lint ==="
npm run lint
echo "=== Pre-commit: lint passed ==="

echo "=== Pre-commit: running tests ==="
npm test
echo "=== Pre-commit: all tests passed ==="

echo "=== Pre-commit: running backend build ==="
npm run build
echo "=== Pre-commit: backend build passed ==="

echo "=== Pre-commit: running frontend build (tsc + vite) ==="
cd frontend && npm run build && cd ..
echo "=== Pre-commit: frontend build passed ==="

echo "=== Pre-commit: running e2e tests ==="
npx playwright test
echo "=== Pre-commit: e2e tests passed ==="

echo "=== Pre-commit: checking documentation ==="
# Warn if source files changed but no docs/ files changed.
# New features, API changes, and behavior changes should almost always touch docs/.
_staged_src=$(git diff --cached --name-only | grep -E '^src/|^frontend/src/' || true)
_staged_docs=$(git diff --cached --name-only | grep '^docs/' || true)
if [[ -n "$_staged_src" && -z "$_staged_docs" ]]; then
  echo ""
  echo "WARNING: source files changed but no docs/ files were updated."
  echo "  Changed source files:"
  echo "$_staged_src" | sed 's/^/    /'
  echo ""
  echo "  Docs should be updated for: new features, API changes, behavior changes,"
  echo "  new config options, and anything user-facing. Internal refactors and"
  echo "  bug fixes with no visible behavior change may skip docs."
  echo ""
  # In interactive mode, require explicit confirmation. In non-interactive (CI, dispatch), auto-pass.
  if [[ -t 1 ]]; then
    read -r -p "  Proceed without docs update? [y/N] " _confirm
    if [[ ! "$_confirm" =~ ^[Yy]$ ]]; then
      echo "Commit aborted. Update docs/ and re-commit."
      exit 1
    fi
  fi
fi
echo "=== Pre-commit: all checks passed ==="
