#!/usr/bin/env bash
# Pre-commit hook: run lint + tests before allowing commits.
# This prevents broken commits from reaching the public repo.
#
# Install: git config core.hooksPath .githooks
set -euo pipefail

# Use fast KDF for crypto tests — matches CI behavior.
# Production Argon2id params are too slow for
# a pre-commit hook. Matches CI behavior.
export STORK_FAST_KDF=1

# Heartbeat: emit a progress marker every 30s so long-running stages
# don't look like they've hung (especially in non-TTY contexts).
_heartbeat_pid=
_start_heartbeat() {
  (while true; do sleep 30; echo "[pre-commit heartbeat: $(date +%H:%M:%S)]"; done) &
  _heartbeat_pid=$!
}
_stop_heartbeat() {
  if [[ -n "${_heartbeat_pid:-}" ]]; then
    kill "$_heartbeat_pid" 2>/dev/null || true
    wait "$_heartbeat_pid" 2>/dev/null || true
    _heartbeat_pid=
  fi
}
trap _stop_heartbeat EXIT
_start_heartbeat

echo "=== Pre-commit: running lint ==="
npm run lint
echo "=== Pre-commit: lint passed ==="

echo "=== Pre-commit: running tests ==="
npm test
echo "=== Pre-commit: all tests passed ==="

echo "=== Pre-commit: running backend build ==="
npm run build
echo "=== Pre-commit: backend build passed ==="

echo "=== Pre-commit: running frontend build (tsc + vite) ==="
cd frontend && npm run build && cd ..
echo "=== Pre-commit: frontend build passed ==="

echo "=== Pre-commit: running e2e tests ==="
npx playwright test
echo "=== Pre-commit: e2e tests passed ==="

echo "=== Pre-commit: all checks passed ==="
